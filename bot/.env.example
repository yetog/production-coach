# Personal Access Token - quickest path for a headless bot.
# Create at https://developer.audiotool.com/personal-access-tokens
# PATs grant FULL account access - never commit the real .env.
AUDIOTOOL_PAT=

# Project the bot joins: full studio URL, UUID, or projects/<id> name.
AUDIOTOOL_PROJECT_URL=https://beta.audiotool.com/studio?project=<PROJECT_ID>

# --- OAuth alternative (tokens exported from a browser login) ---------------
# Register an app at https://developer.audiotool.com/applications
# Redirect URI MUST be http://127.0.0.1:5173/ (127.0.0.1, NOT localhost;
# trailing slash matters). Scope: project:write (there is no read-only scope).
AUDIOTOOL_CLIENT_ID=
AUDIOTOOL_ACCESS_TOKEN=
AUDIOTOOL_REFRESH_TOKEN=

# Optional: auto-stop spike-live after N seconds (default: run until Ctrl+C)
SPIKE_DURATION_S=
